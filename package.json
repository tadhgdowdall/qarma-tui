{
  "name": "qarma-tui",
  "version": "0.1.0",
  "description": "Terminal UI for running Qarma natural language browser tests locally or in the cloud.",
  "license": "MIT",
  "author": "Tadhg Dowdall",
  "repository": {
    "type": "git",
    "url": "https://github.com/tadhgdowdall/qarma-tui.git"
  },
  "homepage": "https://github.com/tadhgdowdall/qarma-tui",
  "bin": {
    "qarma-tui": "./bin/qarma-tui"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/tadhgdowdall/qarma-tui/issues"
  },
  "type": "module",
  "private": false,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "QARMA_SKIP_SETUP_PROMPT=1 bun run --watch src/index.ts",
    "start": "QARMA_SKIP_SETUP_PROMPT=1 bun run src/index.ts",
    "doctor": "QARMA_SKIP_SETUP_PROMPT=1 bun run src/index.ts doctor",
    "setup": "QARMA_SKIP_SETUP_PROMPT=1 bun run src/index.ts setup",
    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.86"
  }
}
